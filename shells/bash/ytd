#!/bin/bash
# SPDX-License-Identifier: GPL-3.0-only

ytd() {
    err() {
        trap - INT TERM EXIT

        if [ "$1" != 0 ]; then
            printf "%s" \
'
$1 -> url
$2 -> fname
$3 *0* -> `--format bestaudio[format_id~=^140][language^=en]`, yt-dlp only
$3 *1* -> `--format bestvideo[height<=1080]`, yt-dlp only
$3 *2* -> `--format bestvideo[height<=1440]`, yt-dlp only
$3 *a* -> write the auto-generated subs
$3 *b* -> `--format bestaudio`, `--format bestvideo`
$3 *m* -> dont use `--mtime`
$3 *n* -> `--fixup never`
$3 *o* -> dont use `-o`
$3 *s* -> convert subtitles to `srt` using ffmpeg before embed
$3 *t* -> `--no-part --no-cache-dir`, keep in tmp dir, no cleanup
$4 *u* -> work in current dir
$3 *v* -> `--verbose`
$3 *x* -> dont try to download any subtitles
$3 *y* -> use yt-dlp
$3 *z* -> use youtube-dl
'

            rm -rf "${TMPDIR:-/tmp}"/ytd \
                   "${TMPDIR:-/tmp}"/yt_a \
                   "${TMPDIR:-/tmp}"/yt_s \
                   "${TMPDIR:-/tmp}"/yt_v \
                   "${TMPDIR:-/tmp}"/ffmpeg_merge
        fi

        case "$OPTS" in
            *u*)
                rm -rf "$DIR"/.ytd "$DIR"/.yt_v "$DIR"/.ffmpeg_merge
            ;;
            *t*)
                :
            ;;
            *)
                rm -rf "${TMPDIR:-/tmp}"/ytd \
                       "${TMPDIR:-/tmp}"/yt_a \
                       "${TMPDIR:-/tmp}"/yt_s \
                       "${TMPDIR:-/tmp}"/yt_v \
                       "${TMPDIR:-/tmp}"/ffmpeg_merge
            ;;
        esac

        exit "$1"
    }

    set -e
    trap "err \$?" INT TERM EXIT

    URL="$1"
    FNAME="$2"
    OPTS="$3"
    DIR="$PWD"
    FILE=

    [ "$URL" ] || { printf "%s\n" 'No URL specified.'; exit 2; }

    case "$FNAME" in
        *.???) FNAME="${FNAME%????}" ;;
        *.????) FNAME="${FNAME%?????}" ;;
    esac

    case "$OPTS" in
        *u*)
            # custom empty dir is still needed; otherwise the glob match cannot
            # be trusted
            mkdir "$DIR"/.ytd
            cd "$DIR"/.ytd
        ;;
        *)
            rm -rf "${TMPDIR:-/tmp}"/ytd
            mkdir "${TMPDIR:-/tmp}"/ytd
            cd "${TMPDIR:-/tmp}"/ytd
        ;;
    esac

    yt_a "$URL" "$FNAME" t"$OPTS"
    yt_v "$URL" "$FNAME" t"$OPTS"
    case "$OPTS" in
        *u*)
            # uses `mv -f`; no need to immediately remove empty dirs afterwards
            ffmpeg_merge "$DIR"/.ytd/* "${TMPDIR:-/tmp}"/yt_a/* '' tu
        ;;
        *)
            ffmpeg_merge "${TMPDIR:-/tmp}"/yt_v/* "${TMPDIR:-/tmp}"/yt_a/* '' t
            mv "${TMPDIR:-/tmp}"/ffmpeg_merge/* "${TMPDIR:-/tmp}"/ytd/
            rm -rf "${TMPDIR:-/tmp}"/ffmpeg_merge "${TMPDIR:-/tmp}"/yt_v
        ;;
    esac

    case "$OPTS" in
        *x*)
            :
        ;;
        *)
            echo 'Trying subtitles...'

            if yt_s "$URL" "$FNAME" t"$OPTS" > /dev/null || \
               { echo 'Trying auto-generated subtitles...' && \
               yt_s "$URL" "$FNAME" at"$OPTS" > /dev/null; }; then
                case "$OPTS" in
                    *u*)
                        # uses `mv -f`; no need to immediately remove empty
                        # dirs afterwards
                        ffmpeg_merge "$DIR"/.ytd/* "${TMPDIR:-/tmp}"/yt_s/* '' stu
                    ;;
                    *)
                        ffmpeg_merge "${TMPDIR:-/tmp}"/ytd/* "${TMPDIR:-/tmp}"/yt_s/* '' st
                        mv -f "${TMPDIR:-/tmp}"/ffmpeg_merge/* "${TMPDIR:-/tmp}"/ytd/
                        rm -rf "${TMPDIR:-/tmp}"/ffmpeg_merge
                    ;;
                esac
            else
                printf "%b%s%b\n" '\033[1;37m' 'No subtitles available.' '\033[0m'
            fi
        ;;
    esac

    FILE=$(set -- *; printf "%s" "${1}x")
    FILE="${FILE%?}"

    if [ "$FNAME" ]; then
        case "$FILE" in
            "${FNAME}.${FILE##*.}")
                :
            ;;
            *)
                mv "$FILE" "${FNAME}.${FILE##*.}"

                FILE="${FNAME}.${FILE##*.}"
            ;;
        esac
    fi

    case "$OPTS" in
        *u*)
            mv "$FILE" "$DIR"/"$FILE"

            printf "%b%s%b %b%s%b\n" \
                '\033[1;32m' 'FILE:' '\033[0m' \
                '\033[1;37m' "$DIR"/"$FILE" '\033[0m'
        ;;
        *t*)
            printf "%b%s%b %b%s%b\n" \
                '\033[1;32m' 'FILE:' '\033[0m' \
                '\033[1;37m' "${TMPDIR:-/tmp}"/ytd/"$FILE" '\033[0m'
        ;;
        *)
            mv "${TMPDIR:-/tmp}"/ytd/"$FILE" "$DIR"/"$FILE"

            printf "%b%s%b %b%s%b\n" \
                '\033[1;32m' 'FILE:' '\033[0m' \
                '\033[1;37m' "$DIR"/"$FILE" '\033[0m'
        ;;
    esac
}

ytd "$@"
